---
import Star from 'astro-heroicons/solid/Star.astro';
---

<section class="relative bg-white overflow-hidden">
	<!-- Bal ~1/3 | Jobb ~2/3, a jobb 100vh – a képre hasonló elrendezés -->
	<div class="container mx-auto grid lg:grid-cols-[2fr_3fr] gap-0 items-stretch min-h-0">
		<!-- Bal: cím, szöveg, CTA, értékelés – középre igazítva a 100vh mellett -->
		<div class="flex flex-col justify-center px-4 sm:px-6 lg:px-8 lg:pr-10 py-12 sm:py-16 lg:py-20">
			<h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] xl:text-5xl font-bold text-black leading-[1.15] tracking-tight">
				Lorem ipsum dolor sit amet, consectetur adipiscing elit.
			</h1>
			<p class="mt-5 lg:mt-6 text-base sm:text-lg text-neutral-800 leading-relaxed max-w-xl">
				Curabitur lobortis fermentum nunc a commodo. Nulla eu purus in libero suscipit efficitur ac sit amet ipsum. Nullam ullamcorper, nunc at facilisis consequat, felis elit consectetur ante, sit amet molestie neque dui vitae.
			</p>
			<div class="mt-8 flex flex-wrap items-center gap-6">
				<a
					href="#kapcsolat"
					class="inline-flex items-center justify-center rounded-full bg-black text-white font-semibold px-8 py-5 hover:opacity-90 transition-opacity no-underline shrink-0"
				>
					KAPCSOLAT
				</a>
				<span class="w-px h-10 bg-neutral-300 shrink-0" aria-hidden="true"></span>
				<div class="flex flex-col gap-0.5">
					<span class="flex gap-0.5 text-amber-500" aria-hidden="true">
						<Star class="w-4 h-4" />
						<Star class="w-4 h-4" />
						<Star class="w-4 h-4" />
						<Star class="w-4 h-4" />
						<Star class="w-4 h-4" />
					</span>
					<span class="text-sm text-neutral-400">90+ sikeres projekt</span>
				</div>
			</div>
		</div>

		<!-- Jobb: 3 oszlop, 100vh, végtelenített mozgás (pontosan 2× tartalom → zökkenőmentes hurok) -->
		<div class="grid grid-cols-3 gap-2 sm:gap-3 w-full h-screen min-h-[280px] overflow-hidden">
			<!-- 1. oszlop: fentről lefelé -->
			<div class="hero-column overflow-hidden rounded-l-lg">
				<div class="hero-column-inner hero-scroll-down">
					<div class="hero-column-page">
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
					</div>
					<div class="hero-column-page">
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
					</div>
				</div>
			</div>
			<!-- 2. oszlop: lentről felfelé (ellentétes) -->
			<div class="hero-column overflow-hidden">
				<div class="hero-column-inner hero-scroll-up-slow">
					<div class="hero-column-page">
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
					</div>
					<div class="hero-column-page">
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
					</div>
				</div>
			</div>
			<!-- 3. oszlop: fentről lefelé, lassabban -->
			<div class="hero-column overflow-hidden rounded-r-lg">
				<div class="hero-column-inner hero-scroll-down-slow">
					<div class="hero-column-page">
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
					</div>
					<div class="hero-column-page">
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
						<div class="hero-block"></div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- Gradient overlay felül (menü alatt): kék árnyalatból átlátszó -->
	<div
		class="absolute inset-x-0 top-0 h-24 sm:h-32 pointer-events-none bg-gradient-to-b from-blue-50 to-transparent"
		aria-hidden="true"
	></div>
	<!-- Gradient overlay az alján, az egész szekció fölé (absolute) -->
	<div
		class="absolute inset-x-0 bottom-0 h-24 sm:h-32 pointer-events-none bg-gradient-to-b from-transparent to-teal-100/80"
		aria-hidden="true"
	></div>
</section>

<style>
	.hero-column {
		height: 100%;
		min-height: 280px;
	}
	@media (min-width: 640px) {
		.hero-column {
			min-height: 340px;
		}
	}

	/* Végtelenített mozgás: inner = 2× magasság, két egyforma "oldal" → -50% = pont egy teljes lap, hurok zökkenőmentes */
	.hero-column-inner {
		height: 200%;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	@media (min-width: 640px) {
		.hero-column-inner {
			gap: 0.75rem;
		}
	}
	.hero-column-page {
		height: 50%;
		min-height: 50%;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	@media (min-width: 640px) {
		.hero-column-page {
			gap: 0.75rem;
		}
	}
	.hero-block {
		position: relative;
		width: 100%;
		padding-bottom: 80%; /* 1.25:1 arány (magasság = szélesség / 1.25) */
		flex: 0 0 auto;
	}
	.hero-block::before {
		content: "";
		position: absolute;
		inset: 0;
		background-color: rgb(229 231 235);
	}

	/* Fentről lefelé – 1. oszlop */
	@keyframes heroScrollDown {
		from {
			transform: translateY(0);
		}
		to {
			transform: translateY(-50%);
		}
	}
	.hero-scroll-down {
		animation: heroScrollDown 20s linear infinite;
	}

	/* Lentről felfelé – 2. oszlop (ellentétes, ugyanolyan sebesség) */
	@keyframes heroScrollUp {
		from {
			transform: translateY(-50%);
		}
		to {
			transform: translateY(0);
		}
	}
	.hero-scroll-up {
		animation: heroScrollUp 20s linear infinite;
	}
	.hero-scroll-up-slow {
		animation: heroScrollUp 30s linear infinite;
	}

	/* Fentről lefelé, lassabban – 3. oszlop */
	.hero-scroll-down-slow {
		animation: heroScrollDown 30s linear infinite;
	}
</style>
